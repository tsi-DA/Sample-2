<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Contact — Norrland</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:wght@500;600;700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="style.css">
</head>
<body>

  <!-- Navbar -->
  <header class="nav">
    <div class="nav__inner">
      <a href="index.html" class="nav__brand">Norrland</a>
      <button class="nav__toggle" aria-label="Toggle menu">☰</button>
      <nav class="nav__links">
        <a href="index.html">Home</a>
        <a href="products.html">Shop</a>
        <a href="cart.html">Cart (<span id="cart-count">0</span>)</a>
        <a href="about.html">About</a>
        <a href="contact.html" class="active">Contact</a>
      </nav>
    </div>
  </header>

  <!-- Contact -->
  <section class="container section">
    <h2 class="section-title">Get in touch</h2>
    <p class="section-sub">Questions about an order, a product, or anything else — we read every message.</p>

    <form class="contact-form" onsubmit="return handleContact(event)">
      <div>
        <label for="contact-name">Name</label>
        <input type="text" id="contact-name" name="name" required placeholder="Your name">
      </div>
      <div>
        <label for="contact-email">Email</label>
        <input type="email" id="contact-email" name="email" required placeholder="you@example.com">
      </div>
      <div>
        <label for="contact-message">Message</label>
        <textarea id="contact-message" name="message" required placeholder="How can we help?"></textarea>
      </div>
      <button class="btn" type="submit">Send Message</button>
    </form>
  </section>

  <!-- Footer -->
  <footer class="footer">
    <div class="container footer__inner">
      <div>
        <p class="nav__brand">Norrland</p>
        <p class="footer__copy">© 2026 Norrland. All rights reserved.</p>
      </div>
      <nav class="footer__links">
        <a href="products.html">Shop</a>
        <a href="about.html">About</a>
        <a href="contact.html">Contact</a>
      </nav>
    </div>
  </footer>

  <script src="products.js"></script>
  <script src="script.js"></script>
</body>
</html>
